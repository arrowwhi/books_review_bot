# Telegram
BOT_TOKEN=your_bot_token_here

# Режим работы бота: webhook | polling
BOT_MODE=webhook

# Webhook (только при BOT_MODE=webhook)
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PORT=8443
WEBHOOK_PATH=/tg

# PostgreSQL
DATABASE_URL=postgres://books:books@postgres:5432/books_bot?sslmode=disable

# APIs
ANTHROPIC_API_KEY=your_anthropic_key_here

# Логирование: debug | info | warn | error
LOG_LEVEL=info
